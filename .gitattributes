# Normalize line endings repo-wide to LF.
#
# Skills ship executable shell/python scripts. When a host with
# core.autocrlf=true checks out the repo (e.g. the remote plugin-install
# path), LF scripts get rewritten to CRLF and their shebangs break
# (`env: 'bash\r': No such file or directory`). Pinning eol=lf here
# overrides core.autocrlf so checkouts stay LF regardless of host config.

* text=auto eol=lf

# Scripts must always be LF — CRLF breaks shebangs and `source`.
*.sh    text eol=lf
*.bash  text eol=lf
*.zsh   text eol=lf
*.py    text eol=lf

# Binary assets — never apply text/eol normalization.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.gz    binary
*.woff  binary
*.woff2 binary
