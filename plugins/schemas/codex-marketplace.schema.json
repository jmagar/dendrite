{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/jmagar/dendrite/plugins/schemas/codex-marketplace.schema.json",
  "title": "Codex Marketplace Manifest",
  "description": "Docs-derived schema for .agents/plugins/marketplace.json. Based on OpenAI Codex plugin docs and the current Codex marketplace parser; Codex does not currently publish a standalone JSON Schema.",
  "type": "object",
  "additionalProperties": true,
  "required": ["name", "plugins"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "object",
      "additionalProperties": true
    },
    "description": {
      "type": "string"
    },
    "interface": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "displayName": {
          "type": "string"
        }
      }
    },
    "plugins": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/pluginEntry"
      }
    }
  },
  "definitions": {
    "pluginEntry": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "source"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "source": {
          "oneOf": [
            {
              "type": "string",
              "pattern": "^\\./"
            },
            {
              "$ref": "#/definitions/localSource"
            },
            {
              "$ref": "#/definitions/urlSource"
            },
            {
              "$ref": "#/definitions/gitSubdirSource"
            }
          ]
        },
        "policy": {
          "$ref": "#/definitions/policy"
        },
        "category": {
          "type": "string"
        },
        "interface": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "localSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "path"],
      "properties": {
        "source": {
          "const": "local"
        },
        "path": {
          "type": "string",
          "pattern": "^\\./"
        }
      }
    },
    "urlSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "url"],
      "properties": {
        "source": {
          "const": "url"
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "sha": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "gitSubdirSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "url", "path"],
      "properties": {
        "source": {
          "const": "git-subdir"
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "sha": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "installation": {
          "enum": ["NOT_AVAILABLE", "AVAILABLE", "INSTALLED_BY_DEFAULT"]
        },
        "authentication": {
          "enum": ["ON_INSTALL", "ON_USE"]
        },
        "products": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
