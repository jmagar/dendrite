#!/usr/bin/env python3
"""Generate Gemini CLI extension manifests for every Dendrite plugin."""

from __future__ import annotations

import json
import re
from pathlib import Path
from typing import Any


ROOT = Path(__file__).resolve().parents[2]
PLUGINS = ROOT / "plugins"
DEFAULT_VERSION = "0.1.0"

FALLBACK_DESCRIPTIONS = {
    "broadcastr": "Helper assets for Broadcastr plugin tooling.",
    "scripts": "Shared Dendrite plugin maintenance scripts.",
}


def read_json(path: Path) -> dict[str, Any]:
    return json.loads(path.read_text())


def load_plugin_manifest(plugin_dir: Path) -> dict[str, Any]:
    codex = plugin_dir / ".codex-plugin" / "plugin.json"
    claude = plugin_dir / ".claude-plugin" / "plugin.json"
    if codex.exists():
        return read_json(codex)
    if claude.exists():
        return read_json(claude)
    return {}


def env_name(config_key: str) -> str:
    return re.sub(r"[^A-Z0-9]+", "_", config_key.upper()).strip("_")


def is_sensitive(name: str, config: dict[str, Any] | None = None) -> bool:
    lowered = name.lower()
    return bool(config and config.get("sensitive")) or any(
        marker in lowered
        for marker in ("token", "secret", "password", "api_key", "apikey", "key")
    )


def settings_from_user_config(user_config: dict[str, Any]) -> list[dict[str, Any]]:
    settings: list[dict[str, Any]] = []
    for key in sorted(user_config):
        config = user_config[key] or {}
        title = config.get("title") or key.replace("_", " ").title()
        description = config.get("description") or f"Value for {key}."
        if "default" in config:
            description = f"{description} Default: {config['default']!r}."
        settings.append(
            {
                "name": title,
                "description": description,
                "envVar": env_name(key),
                "sensitive": is_sensitive(key, config),
            }
        )
    return settings


PLACEHOLDER_RE = re.compile(r"\$\{(?:userConfig|user_config)\.([A-Za-z0-9_]+)\}")
ENV_REF_RE = re.compile(r"\$\{([A-Z][A-Z0-9_]+)\}")


def transform_value(value: Any) -> Any:
    if isinstance(value, str):
        value = PLACEHOLDER_RE.sub(lambda m: "${" + env_name(m.group(1)) + "}", value)
        value = value.replace("${CLAUDE_PLUGIN_ROOT}", "${extensionPath}")
        value = value.replace("${GEMINI_EXTENSION_ROOT}", "${extensionPath}")
        value = value.replace("${CLAUDE_PLUGIN_DATA}", "${extensionPath}${/}.data")
        return value
    if isinstance(value, list):
        return [transform_value(item) for item in value]
    if isinstance(value, dict):
        return {key: transform_value(item) for key, item in value.items()}
    return value


def transform_mcp_server(server: Any) -> Any:
    if not isinstance(server, dict):
        return transform_value(server)

    transformed = transform_value(server)
    env = transformed.get("env")
    if isinstance(env, dict):
        for key, value in list(env.items()):
            if value == "" and re.fullmatch(r"[A-Z][A-Z0-9_]*", key):
                env[key] = "${" + key + "}"
    return transformed


def settings_from_mcp_env(mcp_servers: dict[str, Any], existing: set[str]) -> list[dict[str, Any]]:
    settings: list[dict[str, Any]] = []
    for server in mcp_servers.values():
        if not isinstance(server, dict):
            continue
        env = server.get("env")
        if not isinstance(env, dict):
            continue
        for key, value in sorted(env.items()):
            if key in existing or value not in ("", None):
                continue
            settings.append(
                {
                    "name": key.replace("_", " ").title(),
                    "description": f"Optional environment value for {key}.",
                    "envVar": key,
                    "sensitive": is_sensitive(key),
                }
            )
            existing.add(key)
    return settings


def collect_env_refs(value: Any) -> set[str]:
    refs: set[str] = set()
    if isinstance(value, str):
        refs.update(ENV_REF_RE.findall(value))
    elif isinstance(value, list):
        for item in value:
            refs.update(collect_env_refs(item))
    elif isinstance(value, dict):
        for item in value.values():
            refs.update(collect_env_refs(item))
    return refs


def settings_from_env_refs(mcp_servers: dict[str, Any], existing: set[str]) -> list[dict[str, Any]]:
    settings: list[dict[str, Any]] = []
    ignored = {"extensionPath"}
    for key in sorted(collect_env_refs(mcp_servers)):
        if key in ignored or key in existing:
            continue
        settings.append(
            {
                "name": key.replace("_", " ").title(),
                "description": f"Environment value for {key}.",
                "envVar": key,
                "sensitive": is_sensitive(key),
            }
        )
        existing.add(key)
    return settings


def load_mcp_servers(plugin_dir: Path) -> dict[str, Any]:
    path = plugin_dir / ".mcp.json"
    if not path.exists():
        return {}
    data = read_json(path)
    servers = data.get("mcpServers") or {}
    return {key: transform_mcp_server(value) for key, value in servers.items()}


def manifest_for(plugin_dir: Path) -> dict[str, Any]:
    directory_name = plugin_dir.name
    plugin = load_plugin_manifest(plugin_dir)
    interface = plugin.get("interface") or {}
    description = (
        plugin.get("description")
        or interface.get("shortDescription")
        or FALLBACK_DESCRIPTIONS.get(directory_name)
        or f"Gemini CLI extension for the {directory_name} plugin."
    )

    manifest: dict[str, Any] = {
        "name": directory_name,
        "version": str(plugin.get("version") or DEFAULT_VERSION),
        "description": description,
    }

    user_config = plugin.get("userConfig") or {}
    settings = settings_from_user_config(user_config)
    existing_env = {setting["envVar"] for setting in settings}

    mcp_servers = load_mcp_servers(plugin_dir)
    if mcp_servers:
        manifest["mcpServers"] = mcp_servers
        settings.extend(settings_from_env_refs(mcp_servers, existing_env))
        settings.extend(settings_from_mcp_env(mcp_servers, existing_env))

    if settings:
        manifest["settings"] = settings

    if (plugin_dir / "GEMINI.md").exists():
        manifest["contextFileName"] = "GEMINI.md"

    return manifest


def main() -> None:
    for plugin_dir in sorted(path for path in PLUGINS.iterdir() if path.is_dir()):
        manifest = manifest_for(plugin_dir)
        output = plugin_dir / "gemini-extension.json"
        output.write_text(json.dumps(manifest, indent=2, ensure_ascii=True) + "\n")
        print(output.relative_to(ROOT))


if __name__ == "__main__":
    main()
