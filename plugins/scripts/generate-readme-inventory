#!/usr/bin/env python3
"""Generate the root README plugin inventory block."""

from __future__ import annotations

import argparse
import json
import sys
from dataclasses import dataclass
from pathlib import Path
from typing import Any


ROOT = Path(__file__).resolve().parents[2]
README = ROOT / "README.md"
PLUGINS = ROOT / "plugins"
CLAUDE_MARKETPLACE = ROOT / ".claude-plugin" / "marketplace.json"
CODEX_MARKETPLACE = ROOT / ".agents" / "plugins" / "marketplace.json"

BEGIN = "<!-- BEGIN GENERATED README INVENTORY -->"
END = "<!-- END GENERATED README INVENTORY -->"

FALLBACK_DESCRIPTIONS = {
    "broadcastr": "Helper assets for Broadcastr plugin tooling.",
    "scripts": "Shared Dendrite plugin maintenance scripts.",
}


@dataclass(frozen=True)
class Marketplace:
    count: int
    names: set[str]


@dataclass(frozen=True)
class PluginInventory:
    name: str
    description: str
    skills: list[str]
    mcp_servers: list[str]
    openai_agents: int
    commands: list[str]


def read_json(path: Path) -> Any:
    return json.loads(path.read_text())


def marketplace(path: Path) -> Marketplace:
    data = read_json(path)
    plugins = data.get("plugins")
    if not isinstance(plugins, list):
        raise ValueError(f"{path.relative_to(ROOT)} must contain a plugins array")

    names = set()
    for index, item in enumerate(plugins, start=1):
        if not isinstance(item, dict) or not isinstance(item.get("name"), str):
            raise ValueError(
                f"{path.relative_to(ROOT)} plugin entry {index} is missing a string name"
            )
        names.add(item["name"])

    return Marketplace(count=len(plugins), names=names)


def plugin_dirs() -> list[Path]:
    return sorted(path for path in PLUGINS.iterdir() if path.is_dir())


def plugin_manifest(plugin_dir: Path) -> dict[str, Any]:
    for relative in (
        ".codex-plugin/plugin.json",
        ".claude-plugin/plugin.json",
        "gemini-extension.json",
    ):
        path = plugin_dir / relative
        if path.exists():
            data = read_json(path)
            if isinstance(data, dict):
                return data
    return {}


def description_for(plugin_dir: Path) -> str:
    manifest = plugin_manifest(plugin_dir)
    interface = manifest.get("interface") if isinstance(manifest.get("interface"), dict) else {}
    return (
        manifest.get("description")
        or interface.get("shortDescription")
        or FALLBACK_DESCRIPTIONS.get(plugin_dir.name)
        or "No description found."
    )


def skill_dirs(plugin_dir: Path) -> list[Path]:
    skills_root = plugin_dir / "skills"
    if not skills_root.exists():
        return []
    return sorted(path.parent for path in skills_root.glob("*/SKILL.md") if path.is_file())


def command_docs(plugin_dir: Path) -> list[Path]:
    commands_root = plugin_dir / "commands"
    if not commands_root.exists():
        return []
    return sorted(path for path in commands_root.glob("*.md") if path.is_file())


def mcp_servers(plugin_dir: Path) -> list[str]:
    path = plugin_dir / ".mcp.json"
    if not path.exists():
        return []
    data = read_json(path)
    servers = data.get("mcpServers") if isinstance(data, dict) else None
    if not isinstance(servers, dict):
        return []
    return sorted(servers.keys())


def missing_openai_companions() -> list[Path]:
    missing = []
    for skill in sorted(PLUGINS.glob("*/skills/*/SKILL.md")):
        companion = skill.parent / "agents" / "openai.yaml"
        if not companion.exists():
            missing.append(companion.relative_to(ROOT))
    return missing


def local_inventory() -> list[PluginInventory]:
    rows = []
    for plugin_dir in plugin_dirs():
        skills = [path.name for path in skill_dirs(plugin_dir)]
        commands = [path.name for path in command_docs(plugin_dir)]
        openai_agents = sum(
            1 for path in skill_dirs(plugin_dir) if (path / "agents" / "openai.yaml").exists()
        )
        rows.append(
            PluginInventory(
                name=plugin_dir.name,
                description=description_for(plugin_dir),
                skills=skills,
                mcp_servers=mcp_servers(plugin_dir),
                openai_agents=openai_agents,
                commands=commands,
            )
        )
    return rows


def markdown_escape(value: str) -> str:
    return value.replace("|", "\\|").replace("\n", " ").strip()


def list_cell(values: list[str]) -> str:
    return ", ".join(markdown_escape(value) for value in values) if values else "none"


def generated_block() -> tuple[str, list[str]]:
    claude = marketplace(CLAUDE_MARKETPLACE)
    codex = marketplace(CODEX_MARKETPLACE)
    rows = local_inventory()

    skill_count = len(list(PLUGINS.glob("*/skills/*/SKILL.md")))
    openai_count = len(list(PLUGINS.glob("*/skills/*/agents/openai.yaml")))
    gemini_count = len(list(PLUGINS.glob("*/gemini-extension.json")))
    mcp_files = sorted(PLUGINS.glob("*/.mcp.json"))
    mcp_server_count = sum(len(mcp_servers(path.parent)) for path in mcp_files)
    command_count = len(list(PLUGINS.glob("*/commands/*.md")))

    warnings: list[str] = []
    if claude.names != codex.names:
        claude_only = sorted(claude.names - codex.names)
        codex_only = sorted(codex.names - claude.names)
        details = []
        if claude_only:
            details.append(f"Claude-only: {', '.join(claude_only)}")
        if codex_only:
            details.append(f"Codex-only: {', '.join(codex_only)}")
        warnings.append("Marketplace entries are not aligned. " + "; ".join(details))

    missing_companions = missing_openai_companions()
    if missing_companions:
        warnings.append(
            "Missing OpenAI companion files: "
            + ", ".join(str(path) for path in missing_companions)
        )

    lines = [
        BEGIN,
        "",
        "<!-- Generated by plugins/scripts/generate-readme-inventory. Do not edit by hand. -->",
        "",
        f"- {len(rows)} local plugin directories",
        f"- {claude.count} Claude marketplace entries",
        f"- {codex.count} Codex/OpenAI marketplace entries",
        f"- {skill_count} skills",
        f"- {openai_count} OpenAI agent companion files",
        f"- {gemini_count} Gemini extension manifests",
        f"- {len(mcp_files)} MCP config files, defining {mcp_server_count} MCP servers",
        f"- {command_count} command docs",
        "",
        "| Plugin | Description | Skills | MCP servers | OpenAI agents | Commands |",
        "|---|---|---|---|---:|---|",
    ]

    for row in rows:
        lines.append(
            "| "
            + " | ".join(
                [
                    f"`{markdown_escape(row.name)}`",
                    markdown_escape(row.description),
                    list_cell(row.skills),
                    list_cell(row.mcp_servers),
                    str(row.openai_agents),
                    list_cell(row.commands),
                ]
            )
            + " |"
        )

    lines.extend(["", END])
    return "\n".join(lines), warnings


def replace_inventory(readme: str, block: str) -> str:
    if BEGIN in readme or END in readme:
        if readme.count(BEGIN) != 1 or readme.count(END) != 1:
            raise ValueError("README generated inventory markers are unbalanced")
        before, rest = readme.split(BEGIN, 1)
        _, after = rest.split(END, 1)
        return before.rstrip() + "\n\n" + block + after

    heading = "## Inventory"
    next_heading = "\n## Curated Marketplace Plugins"
    if heading not in readme or next_heading not in readme:
        raise ValueError("README must contain Inventory and Curated Marketplace Plugins sections")

    before, rest = readme.split(heading, 1)
    _, after = rest.split(next_heading, 1)
    return before + heading + "\n\n" + block + "\n" + next_heading + after


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--check", action="store_true", help="verify README is up to date")
    parser.add_argument(
        "--strict",
        action="store_true",
        help="exit nonzero on marketplace drift or missing OpenAI companions",
    )
    args = parser.parse_args()

    block, warnings = generated_block()
    readme = README.read_text()
    updated = replace_inventory(readme, block)

    for warning in warnings:
        print(f"warning: {warning}", file=sys.stderr)

    if args.check:
        if updated != readme:
            print("README.md inventory is out of date", file=sys.stderr)
            return 1
    else:
        README.write_text(updated)
        print(README.relative_to(ROOT))

    if args.strict and warnings:
        return 1
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
