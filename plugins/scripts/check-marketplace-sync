#!/usr/bin/env python3
"""Validate that Claude and Codex marketplace manifests stay aligned."""

from __future__ import annotations

import json
import re
import sys
from collections import Counter
from pathlib import Path
from typing import Any


ROOT = Path(__file__).resolve().parents[2]
PLUGINS = ROOT / "plugins"
CLAUDE_MARKETPLACE = ROOT / ".claude-plugin" / "marketplace.json"
CODEX_MARKETPLACE = ROOT / ".agents" / "plugins" / "marketplace.json"
IGNORED_PLUGIN_DIRS = {"schemas"}
GITHUB_REPO_RE = re.compile(r"^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$")
GIT_SHA_RE = re.compile(r"^[0-9a-fA-F]{7,64}$")


def read_plugins(path: Path) -> list[dict[str, Any]]:
    data = json.loads(path.read_text())
    plugins = data.get("plugins")
    if not isinstance(plugins, list):
        raise ValueError(f"{path.relative_to(ROOT)} must contain a plugins array")
    for index, plugin in enumerate(plugins, start=1):
        if not isinstance(plugin, dict) or not isinstance(plugin.get("name"), str):
            raise ValueError(
                f"{path.relative_to(ROOT)} plugin entry {index} is missing a string name"
            )
    return plugins


def duplicate_names(plugins: list[dict[str, Any]]) -> list[str]:
    counts = Counter(plugin["name"] for plugin in plugins)
    return sorted(name for name, count in counts.items() if count > 1)


def github_url(repo: str) -> str:
    return f"https://github.com/{repo}.git"


def source_label(path: Path, plugin: dict[str, Any]) -> str:
    return f"{path.relative_to(ROOT)}:{plugin.get('name', '<unnamed>')}"


def valid_relative_path(value: str, *, allow_dot_prefix: bool) -> bool:
    if not value or value.startswith("/") or "\\" in value:
        return False
    path_value = value
    if path_value in (".", "./"):
        return allow_dot_prefix
    if path_value.startswith("./"):
        if not allow_dot_prefix:
            return False
        path_value = path_value[2:]
    elif allow_dot_prefix:
        return False
    return all(part not in ("", ".", "..") for part in path_value.split("/"))


def valid_git_url(value: str) -> bool:
    if not value or value.strip() != value:
        return False
    if value.startswith(("https://", "http://", "ssh://", "git@")):
        return True
    if value.startswith(("./", "../", ".\\", "..\\", "/", "file://")):
        return True
    return bool(GITHUB_REPO_RE.fullmatch(value))


def source_selector_errors(label: str, source: dict[str, Any]) -> list[str]:
    errors: list[str] = []
    ref = source.get("ref")
    sha = source.get("sha")
    if ref is not None and (not isinstance(ref, str) or not ref.strip()):
        errors.append(f"{label} source.ref must be a non-empty string when present")
    if sha is not None and (not isinstance(sha, str) or not GIT_SHA_RE.fullmatch(sha)):
        errors.append(f"{label} source.sha must be a 7-64 character hex Git commit when present")
    return errors


def marketplace_source_errors(path: Path, plugins: list[dict[str, Any]]) -> list[str]:
    errors: list[str] = []
    for plugin in plugins:
        label = source_label(path, plugin)
        source = plugin.get("source")
        if isinstance(source, str):
            if not valid_relative_path(source, allow_dot_prefix=True):
                errors.append(f"{label} local source must be a normalized ./ path")
            elif not source.startswith("./plugins/"):
                errors.append(f"{label} local source should stay under ./plugins/")
            continue

        if not isinstance(source, dict):
            errors.append(f"{label} source must be a string or object")
            continue

        source_type = source.get("source")
        if source_type == "local":
            local_path = source.get("path")
            if not isinstance(local_path, str) or not valid_relative_path(
                local_path,
                allow_dot_prefix=True,
            ):
                errors.append(f"{label} local source.path must be a normalized ./ path")
            elif not local_path.startswith("./plugins/"):
                errors.append(f"{label} local source.path should stay under ./plugins/")
        elif source_type == "github":
            repo = source.get("repo")
            if not isinstance(repo, str) or not GITHUB_REPO_RE.fullmatch(repo):
                errors.append(f"{label} github source.repo must look like owner/repo")
            errors.extend(source_selector_errors(label, source))
        elif source_type == "url":
            url = source.get("url")
            if not isinstance(url, str) or not valid_git_url(url):
                errors.append(f"{label} url source.url must be a valid Git URL or owner/repo")
            remote_path = source.get("path")
            if remote_path is not None and (
                not isinstance(remote_path, str)
                or not valid_relative_path(remote_path, allow_dot_prefix=False)
            ):
                errors.append(f"{label} url source.path must be a normalized repository path")
            errors.extend(source_selector_errors(label, source))
        elif source_type == "git-subdir":
            url = source.get("url")
            remote_path = source.get("path")
            if not isinstance(url, str) or not valid_git_url(url):
                errors.append(f"{label} git-subdir source.url must be a valid Git URL or owner/repo")
            if not isinstance(remote_path, str) or not valid_relative_path(
                remote_path,
                allow_dot_prefix=False,
            ):
                errors.append(f"{label} git-subdir source.path must be a normalized repository path")
            errors.extend(source_selector_errors(label, source))
        else:
            errors.append(f"{label} has unsupported source type {source_type!r}")
    return errors


def normalize_source(source: Any) -> tuple[Any, ...]:
    if isinstance(source, str):
        if source.startswith("./"):
            return ("local", source)
        return ("raw", source)

    if not isinstance(source, dict):
        return ("unknown", repr(source))

    source_type = source.get("source")
    if source_type == "local":
        return ("local", source.get("path"))

    if source_type == "github":
        return (
            "repo",
            github_url(str(source.get("repo", ""))),
            source.get("ref"),
            source.get("sha"),
        )

    if source_type == "url":
        return (
            "repo",
            source.get("url"),
            source.get("ref"),
            source.get("sha"),
        )

    if source_type == "git-subdir":
        return (
            "git-subdir",
            source.get("url"),
            source.get("path"),
            source.get("ref"),
            source.get("sha"),
        )

    return (source_type, json.dumps(source, sort_keys=True))


def source_drift(
    claude: dict[str, dict[str, Any]], codex: dict[str, dict[str, Any]]
) -> list[str]:
    drift = []
    for name in sorted(set(claude) & set(codex)):
        claude_source = normalize_source(claude[name].get("source"))
        codex_source = normalize_source(codex[name].get("source"))
        if claude_source != codex_source:
            drift.append(
                f"{name}: Claude source {claude_source!r} != Codex source {codex_source!r}"
            )
    return drift


def missing_gemini_extensions() -> list[str]:
    missing = []
    for plugin_dir in plugin_dirs():
        has_claude = (plugin_dir / ".claude-plugin" / "plugin.json").exists()
        has_codex = (plugin_dir / ".codex-plugin" / "plugin.json").exists()
        has_gemini = (plugin_dir / "gemini-extension.json").exists()
        if (has_claude or has_codex) and not has_gemini:
            manifests = []
            if has_claude:
                manifests.append(".claude-plugin/plugin.json")
            if has_codex:
                manifests.append(".codex-plugin/plugin.json")
            missing.append(f"{plugin_dir.relative_to(ROOT)} has {', '.join(manifests)}")
    return missing


def plugin_dirs() -> list[Path]:
    return sorted(
        path
        for path in PLUGINS.iterdir()
        if path.is_dir() and path.name not in IGNORED_PLUGIN_DIRS
    )


def load_optional_json(path: Path) -> dict[str, Any]:
    if not path.exists():
        return {}
    data = json.loads(path.read_text())
    if not isinstance(data, dict):
        raise ValueError(f"{path.relative_to(ROOT)} must contain a JSON object")
    return data


def skill_names(plugin_dir: Path) -> list[str]:
    skills_dir = plugin_dir / "skills"
    if not skills_dir.exists():
        return []
    return sorted(path.parent.name for path in skills_dir.glob("*/SKILL.md"))


def normalized_skill_path(value: Any) -> str | None:
    if not isinstance(value, str):
        return None
    return value.rstrip("/")


def skill_manifest_drift() -> list[str]:
    drift = []
    for plugin_dir in plugin_dirs():
        skills = skill_names(plugin_dir)
        if not skills:
            continue

        claude_path = plugin_dir / ".claude-plugin" / "plugin.json"
        codex_path = plugin_dir / ".codex-plugin" / "plugin.json"
        gemini_path = plugin_dir / "gemini-extension.json"

        claude = load_optional_json(claude_path)
        codex = load_optional_json(codex_path)

        if claude_path.exists() and normalized_skill_path(claude.get("skills")) != "./skills":
            drift.append(f"{plugin_dir.relative_to(ROOT)} Claude skills must be './skills/'")
        if codex_path.exists() and normalized_skill_path(codex.get("skills")) != "./skills":
            drift.append(f"{plugin_dir.relative_to(ROOT)} Codex skills must be './skills/'")
        if (claude_path.exists() or codex_path.exists()) and not gemini_path.exists():
            drift.append(f"{plugin_dir.relative_to(ROOT)} is missing gemini-extension.json")
    return drift


PLACEHOLDER_RE = re.compile(r"\$\{(?:userConfig|user_config)\.([A-Za-z0-9_]+)\}")
PLUGIN_OPTION_RE = re.compile(r"\b(?:CLAUDE|CODEX)_PLUGIN_OPTION_([A-Z0-9_]+)\b")
USER_CONFIG_REF_RE = re.compile(r"\$\{(?:userConfig|user_config)\.([A-Za-z0-9_]+)\}")


def env_name(config_key: str) -> str:
    return re.sub(r"[^A-Z0-9]+", "_", config_key.upper()).strip("_")


def config_key_from_env(env_var: str) -> str:
    return env_var.lower()


def transform_value(value: Any) -> Any:
    if isinstance(value, str):
        value = PLACEHOLDER_RE.sub(lambda m: "${" + env_name(m.group(1)) + "}", value)
        value = value.replace("${CLAUDE_PLUGIN_ROOT}", "${extensionPath}")
        value = value.replace("${GEMINI_EXTENSION_ROOT}", "${extensionPath}")
        value = value.replace("${CLAUDE_PLUGIN_DATA}", "${extensionPath}${/}.data")
        return value
    if isinstance(value, list):
        return [transform_value(item) for item in value]
    if isinstance(value, dict):
        return {key: transform_value(item) for key, item in value.items()}
    return value


def transform_mcp_server(server: Any) -> Any:
    if not isinstance(server, dict):
        return transform_value(server)

    transformed = transform_value(server)
    env = transformed.get("env")
    if isinstance(env, dict):
        for key, value in list(env.items()):
            if value == "" and re.fullmatch(r"[A-Z][A-Z0-9_]*", key):
                env[key] = "${" + key + "}"
    return transformed


def expected_gemini_mcp_servers(plugin_dir: Path) -> dict[str, Any]:
    mcp_path = plugin_dir / ".mcp.json"
    if not mcp_path.exists():
        return {}
    data = load_optional_json(mcp_path)
    servers = data.get("mcpServers") or {}
    if not isinstance(servers, dict):
        raise ValueError(f"{mcp_path.relative_to(ROOT)} mcpServers must be an object")
    return {key: transform_mcp_server(value) for key, value in servers.items()}


def mcp_manifest_drift() -> list[str]:
    drift = []
    for plugin_dir in plugin_dirs():
        gemini_path = plugin_dir / "gemini-extension.json"
        if not gemini_path.exists():
            continue

        expected = expected_gemini_mcp_servers(plugin_dir)
        gemini = load_optional_json(gemini_path)
        actual = gemini.get("mcpServers") or {}
        if not isinstance(actual, dict):
            drift.append(f"{gemini_path.relative_to(ROOT)} mcpServers must be an object")
            continue

        if actual != expected:
            drift.append(
                f"{plugin_dir.relative_to(ROOT)} Gemini mcpServers do not match .mcp.json"
            )
    return drift


def gemini_setting_env_vars(plugin_dir: Path) -> set[str]:
    gemini = load_optional_json(plugin_dir / "gemini-extension.json")
    settings = gemini.get("settings") or []
    if not isinstance(settings, list):
        return set()
    env_vars = set()
    for setting in settings:
        if isinstance(setting, dict) and isinstance(setting.get("envVar"), str):
            env_vars.add(setting["envVar"])
    return env_vars


def config_reference_files(plugin_dir: Path) -> list[Path]:
    files: list[Path] = []
    for relative in (".mcp.json",):
        path = plugin_dir / relative
        if path.exists():
            files.append(path)
    for subdir in ("hooks", "commands", "scripts", "skills"):
        root = plugin_dir / subdir
        if root.exists():
            files.extend(path for path in root.rglob("*") if path.is_file())
    return sorted(files)


def config_refs_for(plugin_dir: Path) -> tuple[set[str], list[str]]:
    refs: set[str] = set()
    errors: list[str] = []
    for path in config_reference_files(plugin_dir):
        text = path.read_text(errors="ignore")
        refs.update(USER_CONFIG_REF_RE.findall(text))
        for env_ref in PLUGIN_OPTION_RE.findall(text):
            full_match = f"{env_ref}"
            if f"CODEX_PLUGIN_OPTION_{env_ref}" in text:
                errors.append(
                    f"{path.relative_to(ROOT)} references CODEX_PLUGIN_OPTION_{env_ref}, "
                    "but Codex plugins do not have a userConfig/settings option surface"
                )
            refs.add(config_key_from_env(full_match))
    return refs, errors


def config_manifest_drift() -> list[str]:
    drift = []
    for plugin_dir in plugin_dirs():
        claude_path = plugin_dir / ".claude-plugin" / "plugin.json"
        if not claude_path.exists():
            continue

        claude = load_optional_json(claude_path)
        user_config = claude.get("userConfig") or {}
        if not isinstance(user_config, dict):
            drift.append(f"{claude_path.relative_to(ROOT)} userConfig must be an object")
            continue

        user_keys = set(user_config)
        expected_env = {env_name(key) for key in user_keys}
        actual_env = gemini_setting_env_vars(plugin_dir)

        missing_gemini = sorted(expected_env - actual_env)
        extra_gemini = sorted(actual_env - expected_env)
        if missing_gemini:
            drift.append(
                f"{plugin_dir.relative_to(ROOT)} Gemini settings missing env vars: "
                + ", ".join(missing_gemini)
            )
        if extra_gemini:
            drift.append(
                f"{plugin_dir.relative_to(ROOT)} Gemini settings not backed by Claude userConfig: "
                + ", ".join(extra_gemini)
            )

        refs, ref_errors = config_refs_for(plugin_dir)
        drift.extend(ref_errors)
        missing_user_config = sorted(refs - user_keys)
        if missing_user_config:
            drift.append(
                f"{plugin_dir.relative_to(ROOT)} config refs not backed by Claude userConfig: "
                + ", ".join(missing_user_config)
            )

    return drift


def main() -> int:
    try:
        claude_plugins = read_plugins(CLAUDE_MARKETPLACE)
        codex_plugins = read_plugins(CODEX_MARKETPLACE)
    except Exception as exc:
        print(f"marketplace sync check failed: {exc}", file=sys.stderr)
        return 1

    errors: list[str] = []

    claude_dupes = duplicate_names(claude_plugins)
    if claude_dupes:
        errors.append("Claude duplicate plugin names: " + ", ".join(claude_dupes))

    codex_dupes = duplicate_names(codex_plugins)
    if codex_dupes:
        errors.append("Codex duplicate plugin names: " + ", ".join(codex_dupes))

    source_errors = marketplace_source_errors(CLAUDE_MARKETPLACE, claude_plugins)
    source_errors.extend(marketplace_source_errors(CODEX_MARKETPLACE, codex_plugins))
    if source_errors:
        errors.append("Marketplace source validation:\n  " + "\n  ".join(source_errors))

    claude_by_name = {plugin["name"]: plugin for plugin in claude_plugins}
    codex_by_name = {plugin["name"]: plugin for plugin in codex_plugins}

    claude_names = set(claude_by_name)
    codex_names = set(codex_by_name)
    claude_only = sorted(claude_names - codex_names)
    codex_only = sorted(codex_names - claude_names)

    if claude_only:
        errors.append("Claude-only marketplace entries: " + ", ".join(claude_only))
    if codex_only:
        errors.append("Codex-only marketplace entries: " + ", ".join(codex_only))

    drift = source_drift(claude_by_name, codex_by_name)
    if drift:
        errors.append("Source drift:\n  " + "\n  ".join(drift))

    missing_gemini = missing_gemini_extensions()
    if missing_gemini:
        errors.append(
            "Local plugin manifests without gemini-extension.json:\n  "
            + "\n  ".join(missing_gemini)
        )

    skill_drift = skill_manifest_drift()
    if skill_drift:
        errors.append("Skill manifest drift:\n  " + "\n  ".join(skill_drift))

    mcp_drift = mcp_manifest_drift()
    if mcp_drift:
        errors.append("MCP manifest drift:\n  " + "\n  ".join(mcp_drift))

    config_drift = config_manifest_drift()
    if config_drift:
        errors.append("Config manifest drift:\n  " + "\n  ".join(config_drift))

    if errors:
        print("Marketplace manifests are not aligned:", file=sys.stderr)
        for error in errors:
            print(f"- {error}", file=sys.stderr)
        return 1

    print(
        "Marketplace manifests aligned: "
        f"{len(claude_plugins)} Claude entries, {len(codex_plugins)} Codex entries"
    )
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
