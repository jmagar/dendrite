#!/usr/bin/env python3
"""Smoke-test marketplace install flows in isolated homes."""

from __future__ import annotations

import argparse
import json
import os
import shutil
import subprocess
import tempfile
from pathlib import Path
from typing import Any


ROOT = Path(__file__).resolve().parents[2]
SMOKE_PLUGIN = "acp"


def run(command: list[str], *, env: dict[str, str] | None = None, input_text: str | None = None) -> subprocess.CompletedProcess[str]:
    completed = subprocess.run(
        command,
        cwd=ROOT,
        env=env,
        input=input_text,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        check=False,
    )
    if completed.returncode != 0:
        raise RuntimeError(
            f"`{' '.join(command)}` failed with exit {completed.returncode}:\n{completed.stdout}"
        )
    return completed


def command_path(name: str) -> str | None:
    direct = shutil.which(name)
    if direct and "/mise/shims/" not in direct:
        return direct
    mise = shutil.which("mise")
    if mise:
        completed = subprocess.run(
            [mise, "which", name],
            cwd=ROOT,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            check=False,
        )
        candidate = completed.stdout.strip()
        if completed.returncode == 0 and candidate:
            return candidate
    return direct


def require_command(name: str) -> str:
    path = command_path(name)
    if not path:
        raise RuntimeError(f"Required CLI `{name}` was not found on PATH")
    return path


def read_json(path: Path) -> Any:
    return json.loads(path.read_text())


def marketplace_name(path: Path) -> str:
    data = read_json(path / ".agents" / "plugins" / "marketplace.json")
    name = data.get("name")
    if not isinstance(name, str) or not name:
        raise ValueError(f"{path}/.agents/plugins/marketplace.json must declare a marketplace name")
    return name


def marketplace_count(path: Path) -> int:
    data = read_json(path / ".agents" / "plugins" / "marketplace.json")
    plugins = data.get("plugins")
    if not isinstance(plugins, list):
        raise ValueError(f"{path}/.agents/plugins/marketplace.json must contain a plugins array")
    return len(plugins)


def isolated_env(home: Path) -> dict[str, str]:
    env = os.environ.copy()
    env["HOME"] = str(home)
    env["XDG_CONFIG_HOME"] = str(home / ".config")
    env["XDG_DATA_HOME"] = str(home / ".local" / "share")
    env["CODEX_HOME"] = str(home / ".codex")
    env["GEMINI_HOME"] = str(home / ".gemini")
    for relative in (".config", ".local/share", ".codex", ".gemini"):
        (home / relative).mkdir(parents=True, exist_ok=True)
    return env


def smoke_claude(marketplace_path: Path, name: str) -> None:
    claude = require_command("claude")
    with tempfile.TemporaryDirectory(prefix="dendrite-claude-smoke.") as tmp:
        env = isolated_env(Path(tmp))
        run([claude, "plugin", "marketplace", "add", str(marketplace_path), "--scope", "user"], env=env)
        market_output = run([claude, "plugin", "marketplace", "list"], env=env).stdout
        if name not in market_output:
            raise RuntimeError(f"Claude marketplace list did not include {name!r}:\n{market_output}")
        run([claude, "plugin", "install", f"{SMOKE_PLUGIN}@{name}", "--scope", "user"], env=env)
        plugin_output = run([claude, "plugin", "list"], env=env).stdout
        if f"{SMOKE_PLUGIN}@{name}" not in plugin_output:
            raise RuntimeError(f"Claude plugin list did not include {SMOKE_PLUGIN}@{name}:\n{plugin_output}")
    print(f"Claude install smoke passed for {name}")


def smoke_codex(marketplace_path: Path, name: str, expected_count: int) -> None:
    codex = require_command("codex")
    with tempfile.TemporaryDirectory(prefix="dendrite-codex-smoke.") as tmp:
        env = isolated_env(Path(tmp))
        run([codex, "plugin", "marketplace", "add", str(marketplace_path)], env=env)
        market_output = run([codex, "plugin", "marketplace", "list"], env=env).stdout
        if name not in market_output:
            raise RuntimeError(f"Codex marketplace list did not include {name!r}:\n{market_output}")
        run([codex, "plugin", "add", f"{SMOKE_PLUGIN}@{name}"], env=env)
        plugin_output = run([codex, "plugin", "list"], env=env).stdout
        installed = f"{SMOKE_PLUGIN}@{name}"
        if installed not in plugin_output:
            raise RuntimeError(f"Codex plugin list did not include {installed}:\n{plugin_output}")
        listed_count = plugin_output.count(f"@{name}")
        if listed_count != expected_count:
            raise RuntimeError(
                f"Codex listed {listed_count} plugins for {name}, expected {expected_count}"
            )
    print(f"Codex install smoke passed for {name} ({expected_count} plugins)")


def smoke_gemini(plugin_path: Path) -> None:
    gemini = require_command("gemini")
    node = require_command("node")
    with tempfile.TemporaryDirectory(prefix="dendrite-gemini-smoke.") as tmp:
        env = isolated_env(Path(tmp))
        run(
            [node, gemini, "extensions", "install", str(plugin_path), "--consent", "--skip-settings"],
            env=env,
            input_text="y\n",
        )
        output = run([node, gemini, "extensions", "list", "--output-format", "json"], env=env).stdout
        json_start = output.find("[")
        if json_start == -1:
            raise RuntimeError(f"Gemini extension list did not return JSON output:\n{output}")
        extensions = json.loads(output[json_start:])
        if not any(extension.get("name") == SMOKE_PLUGIN for extension in extensions):
            raise RuntimeError(f"Gemini extension list did not include {SMOKE_PLUGIN}:\n{output}")
    print(f"Gemini extension install smoke passed for {SMOKE_PLUGIN}")


def with_ref(ref: str) -> Path:
    tmp_parent = Path(tempfile.mkdtemp(prefix="dendrite-marketplace-smoke."))
    worktree = tmp_parent / "checkout"
    run(["git", "worktree", "add", "--detach", str(worktree), ref])
    return worktree


def cleanup_ref_path(path: Path) -> None:
    tmp_parent = path.parent
    run(["git", "worktree", "remove", "--force", str(path)])
    shutil.rmtree(tmp_parent, ignore_errors=True)


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--path", type=Path, default=ROOT, help="marketplace checkout path")
    parser.add_argument("--ref", help="git ref to smoke via a temporary worktree")
    parser.add_argument("--skip-claude", action="store_true")
    parser.add_argument("--skip-codex", action="store_true")
    parser.add_argument("--skip-gemini", action="store_true")
    args = parser.parse_args()

    marketplace_path = args.path.resolve()
    temp_ref_path: Path | None = None
    try:
        if args.ref:
            temp_ref_path = with_ref(args.ref)
            marketplace_path = temp_ref_path

        name = marketplace_name(marketplace_path)
        expected_count = marketplace_count(marketplace_path)
        print(f"Smoke-testing marketplace {name} at {marketplace_path}")

        if not args.skip_claude:
            smoke_claude(marketplace_path, name)
        if not args.skip_codex:
            smoke_codex(marketplace_path, name, expected_count)
        if not args.skip_gemini:
            smoke_gemini(marketplace_path / "plugins" / SMOKE_PLUGIN)

        print(f"Marketplace install smoke passed for {name}")
        return 0
    finally:
        if temp_ref_path:
            cleanup_ref_path(temp_ref_path)


if __name__ == "__main__":
    raise SystemExit(main())
