#!/usr/bin/env python3
"""Generate Dendrite operational docs from marketplace and plugin manifests."""

from __future__ import annotations

import argparse
import json
import re
import sys
from dataclasses import dataclass
from pathlib import Path
from typing import Any


ROOT = Path(__file__).resolve().parents[2]
DOCS = ROOT / "docs"
PLUGINS = ROOT / "plugins"
CLAUDE_MARKETPLACE = ROOT / ".claude-plugin" / "marketplace.json"
CODEX_MARKETPLACE = ROOT / ".agents" / "plugins" / "marketplace.json"
SCHEMAS = PLUGINS / "schemas"
NO_MCP_SCRIPT = PLUGINS / "scripts" / "apply-no-mcp-marketplace"

IGNORED_PLUGIN_DIRS = {"schemas"}
PLACEHOLDER_RE = re.compile(r"\$\{(?:userConfig|user_config)\.([A-Za-z0-9_]+)\}")
PLUGIN_OPTION_RE = re.compile(r"\b(?:CLAUDE|CODEX)_PLUGIN_OPTION_([A-Z0-9_]+)\b")


@dataclass(frozen=True)
class GeneratedDoc:
    path: Path
    contents: str


@dataclass(frozen=True)
class UpstreamReference:
    runtime: str
    purpose: str
    url: str


UPSTREAM_REFERENCES = [
    UpstreamReference(
        "Claude",
        "published plugin manifest JSON Schema",
        "https://json.schemastore.org/claude-code-plugin-manifest.json",
    ),
    UpstreamReference(
        "Claude",
        "published marketplace JSON Schema",
        "https://json.schemastore.org/claude-code-marketplace.json",
    ),
    UpstreamReference(
        "Codex",
        "plugin manifest reference docs",
        "https://developers.openai.com/codex/plugins/build",
    ),
    UpstreamReference(
        "Codex",
        "sample plugin.json spec carried in the Codex repo",
        "https://github.com/openai/codex/blob/main/codex-rs/skills/src/assets/samples/plugin-creator/references/plugin-json-spec.md",
    ),
    UpstreamReference(
        "Codex",
        "current plugin manifest parser",
        "https://github.com/openai/codex/blob/main/codex-rs/core-plugins/src/manifest.rs",
    ),
    UpstreamReference(
        "Codex",
        "current marketplace parser",
        "https://github.com/openai/codex/blob/main/codex-rs/core-plugins/src/marketplace.rs",
    ),
    UpstreamReference(
        "Gemini",
        "extension manifest reference docs",
        "https://github.com/google-gemini/gemini-cli/blob/main/docs/extensions/reference.md",
    ),
    UpstreamReference(
        "Gemini",
        "ExtensionConfig interface",
        "https://github.com/google-gemini/gemini-cli/blob/main/packages/cli/src/config/extension.ts",
    ),
    UpstreamReference(
        "Gemini",
        "official extension validator implementation",
        "https://github.com/google-gemini/gemini-cli/blob/main/packages/cli/src/commands/extensions/validate.ts",
    ),
]


def read_json(path: Path) -> Any:
    return json.loads(path.read_text())


def read_json_object(path: Path) -> dict[str, Any]:
    data = read_json(path)
    if not isinstance(data, dict):
        raise ValueError(f"{path.relative_to(ROOT)} must contain a JSON object")
    return data


def plugin_dirs() -> list[Path]:
    return sorted(
        path
        for path in PLUGINS.iterdir()
        if path.is_dir() and path.name not in IGNORED_PLUGIN_DIRS
    )


def plugin_dir_by_name() -> dict[str, Path]:
    return {path.name: path for path in plugin_dirs()}


def marketplace_plugins(path: Path) -> list[dict[str, Any]]:
    data = read_json_object(path)
    plugins = data.get("plugins")
    if not isinstance(plugins, list):
        raise ValueError(f"{path.relative_to(ROOT)} must contain a plugins array")
    return [plugin for plugin in plugins if isinstance(plugin, dict)]


def marketplace_by_name(path: Path) -> dict[str, dict[str, Any]]:
    return {
        plugin["name"]: plugin
        for plugin in marketplace_plugins(path)
        if isinstance(plugin.get("name"), str)
    }


def load_optional_json(path: Path) -> dict[str, Any]:
    if not path.exists():
        return {}
    return read_json_object(path)


def first_manifest(plugin_dir: Path) -> dict[str, Any]:
    for relative in (
        ".codex-plugin/plugin.json",
        ".claude-plugin/plugin.json",
        "gemini-extension.json",
    ):
        path = plugin_dir / relative
        if path.exists():
            return read_json_object(path)
    return {}


def description_for(plugin_dir: Path) -> str:
    manifest = first_manifest(plugin_dir)
    interface = manifest.get("interface") if isinstance(manifest.get("interface"), dict) else {}
    return (
        string_or_none(manifest.get("description"))
        or string_or_none(interface.get("shortDescription"))
        or "No description found."
    )


def string_or_none(value: Any) -> str | None:
    return value if isinstance(value, str) and value.strip() else None


def skill_names(plugin_dir: Path) -> list[str]:
    skills_root = plugin_dir / "skills"
    if not skills_root.exists():
        return []
    return sorted(path.parent.name for path in skills_root.glob("*/SKILL.md") if path.is_file())


def command_names(plugin_dir: Path) -> list[str]:
    commands_root = plugin_dir / "commands"
    if not commands_root.exists():
        return []
    return sorted(path.name for path in commands_root.glob("*.md") if path.is_file())


def openai_companion_count(plugin_dir: Path) -> int:
    return sum(
        1
        for skill in skill_names(plugin_dir)
        if (plugin_dir / "skills" / skill / "agents" / "openai.yaml").exists()
    )


def mcp_server_names(plugin_dir: Path) -> list[str]:
    data = load_optional_json(plugin_dir / ".mcp.json")
    servers = data.get("mcpServers") if isinstance(data, dict) else None
    if not isinstance(servers, dict):
        return []
    return sorted(servers)


def user_config(plugin_dir: Path) -> dict[str, Any]:
    for relative in (".claude-plugin/plugin.json", ".codex-plugin/plugin.json"):
        data = load_optional_json(plugin_dir / relative)
        config = data.get("userConfig")
        if isinstance(config, dict) and config:
            return config
    return {}


def gemini_settings(plugin_dir: Path) -> list[dict[str, Any]]:
    data = load_optional_json(plugin_dir / "gemini-extension.json")
    settings = data.get("settings")
    if not isinstance(settings, list):
        return []
    return [setting for setting in settings if isinstance(setting, dict)]


def markdown_escape(value: Any) -> str:
    return str(value).replace("|", "\\|").replace("\n", " ").strip()


def list_cell(values: list[str]) -> str:
    return ", ".join(f"`{markdown_escape(value)}`" for value in values) if values else "none"


def yes_no(value: bool) -> str:
    return "yes" if value else "no"


def env_name(config_key: str) -> str:
    return re.sub(r"[^A-Z0-9]+", "_", config_key.upper()).strip("_")


def config_key_from_env(env_var: str) -> str:
    return env_var.lower()


def config_reference_files(plugin_dir: Path) -> list[Path]:
    files: list[Path] = []
    for relative in (".mcp.json",):
        path = plugin_dir / relative
        if path.exists():
            files.append(path)
    for subdir in ("hooks", "commands", "scripts"):
        root = plugin_dir / subdir
        if root.exists():
            files.extend(path for path in root.rglob("*") if path.is_file())
    return sorted(files)


def config_consumers(plugin_dir: Path) -> dict[str, list[str]]:
    consumers: dict[str, set[str]] = {}
    for path in config_reference_files(plugin_dir):
        text = path.read_text(errors="ignore")
        relative = str(path.relative_to(ROOT))
        for key in PLACEHOLDER_RE.findall(text):
            consumers.setdefault(key, set()).add(relative)
        for env_ref in PLUGIN_OPTION_RE.findall(text):
            consumers.setdefault(config_key_from_env(env_ref), set()).add(relative)
    return {key: sorted(values) for key, values in consumers.items()}


def source_kind(source: Any) -> str:
    if isinstance(source, str):
        return "local" if source.startswith("./") else "raw"
    if not isinstance(source, dict):
        return "unknown"
    return str(source.get("source") or "unknown")


def normalized_source(source: Any) -> str:
    if isinstance(source, str):
        return source
    if not isinstance(source, dict):
        return repr(source)
    source_type = source.get("source")
    if source_type == "local":
        return str(source.get("path", ""))
    if source_type == "github":
        repo = source.get("repo", "")
        return f"https://github.com/{repo}.git"
    if source_type == "url":
        return str(source.get("url", ""))
    if source_type == "git-subdir":
        url = source.get("url", "")
        path = source.get("path", "")
        return f"{url}:{path}"
    return json.dumps(source, sort_keys=True)


def selector_cell(source: Any) -> str:
    if not isinstance(source, dict):
        return "none"
    selectors = []
    if source.get("ref"):
        selectors.append(f"ref=`{markdown_escape(source['ref'])}`")
    if source.get("sha"):
        selectors.append(f"sha=`{markdown_escape(source['sha'])}`")
    return ", ".join(selectors) if selectors else "none"


def no_mcp_names() -> list[str]:
    text = NO_MCP_SCRIPT.read_text()
    match = re.search(r"NO_MCP_REF_NAMES\s*=\s*\{(?P<body>.*?)\}", text, re.S)
    if not match:
        return []
    return sorted(re.findall(r'"([^"]+)"', match.group("body")))


def doc_header(title: str) -> list[str]:
    return [
        f"# {title}",
        "",
        "<!-- Generated by plugins/scripts/generate-docs. Do not edit by hand. -->",
        "",
    ]


def plugin_matrix_doc() -> GeneratedDoc:
    claude = marketplace_by_name(CLAUDE_MARKETPLACE)
    codex = marketplace_by_name(CODEX_MARKETPLACE)
    rows = []
    for plugin_dir in plugin_dirs():
        name = plugin_dir.name
        rows.append(
            [
                f"`{markdown_escape(name)}`",
                markdown_escape(description_for(plugin_dir)),
                yes_no(name in claude),
                yes_no(name in codex),
                yes_no((plugin_dir / "gemini-extension.json").exists()),
                list_cell(skill_names(plugin_dir)),
                list_cell(mcp_server_names(plugin_dir)),
                str(openai_companion_count(plugin_dir)),
                list_cell(command_names(plugin_dir)),
                yes_no((plugin_dir / "README.md").exists()),
                yes_no((plugin_dir / "CHANGELOG.md").exists()),
            ]
        )

    lines = doc_header("Plugin Matrix")
    lines.extend(
        [
            "| Plugin | Description | Claude | Codex | Gemini | Skills | MCP servers | OpenAI agents | Commands | README | CHANGELOG |",
            "|---|---|---:|---:|---:|---|---|---:|---|---:|---:|",
        ]
    )
    lines.extend("| " + " | ".join(row) + " |" for row in rows)
    lines.append("")
    return GeneratedDoc(DOCS / "plugin-matrix.md", "\n".join(lines))


def configuration_matrix_doc() -> GeneratedDoc:
    rows = []
    for plugin_dir in plugin_dirs():
        plugin_name = plugin_dir.name
        consumers = config_consumers(plugin_dir)
        gemini_by_env = {
            setting.get("envVar"): setting
            for setting in gemini_settings(plugin_dir)
            if isinstance(setting.get("envVar"), str)
        }
        keys = set(user_config(plugin_dir))
        keys.update(consumers)
        keys.update(config_key_from_env(env_var) for env_var in gemini_by_env)

        for key in sorted(keys):
            config = user_config(plugin_dir).get(key) or {}
            env_var = env_name(key)
            gemini = gemini_by_env.get(env_var, {})
            sensitive = bool(config.get("sensitive")) or bool(gemini.get("sensitive"))
            title = config.get("title") or gemini.get("name") or key
            description = config.get("description") or gemini.get("description") or ""
            rows.append(
                [
                    f"`{markdown_escape(plugin_name)}`",
                    f"`{markdown_escape(key)}`",
                    f"`{markdown_escape(env_var)}`",
                    markdown_escape(title),
                    yes_no(sensitive),
                    list_cell(consumers.get(key, [])),
                    markdown_escape(description),
                ]
            )

    lines = doc_header("Configuration Matrix")
    lines.extend(
        [
            "| Plugin | Config key | Env var | Title | Sensitive | Consumed by | Description |",
            "|---|---|---|---|---:|---|---|",
        ]
    )
    if rows:
        lines.extend("| " + " | ".join(row) + " |" for row in rows)
    else:
        lines.append("| none | none | none | none | no | none | none |")
    lines.append("")
    return GeneratedDoc(DOCS / "configuration-matrix.md", "\n".join(lines))


def marketplace_sources_doc() -> GeneratedDoc:
    claude = marketplace_by_name(CLAUDE_MARKETPLACE)
    codex = marketplace_by_name(CODEX_MARKETPLACE)
    all_names = sorted(set(claude) | set(codex))
    no_mcp = set(no_mcp_names())
    rows = []
    for name in all_names:
        claude_source = claude.get(name, {}).get("source")
        codex_source = codex.get(name, {}).get("source")
        rows.append(
            [
                f"`{markdown_escape(name)}`",
                markdown_escape(source_kind(claude_source)),
                markdown_escape(normalized_source(claude_source)),
                selector_cell(claude_source),
                markdown_escape(source_kind(codex_source)),
                markdown_escape(normalized_source(codex_source)),
                selector_cell(codex_source),
                yes_no(name in no_mcp),
            ]
        )

    lines = doc_header("Marketplace Sources")
    lines.extend(
        [
            "| Plugin | Claude kind | Claude source | Claude selector | Codex kind | Codex source | Codex selector | no-MCP ref |",
            "|---|---|---|---|---|---|---|---:|",
        ]
    )
    lines.extend("| " + " | ".join(row) + " |" for row in rows)
    lines.append("")
    return GeneratedDoc(DOCS / "marketplace-sources.md", "\n".join(lines))


def schema_provenance_doc() -> GeneratedDoc:
    schema_rows = []
    for schema in sorted(SCHEMAS.glob("*.schema.json")):
        data = read_json_object(schema)
        schema_rows.append(
            [
                f"`{schema.relative_to(ROOT)}`",
                markdown_escape(data.get("title", schema.name)),
                markdown_escape(data.get("description", "")),
            ]
        )

    lines = doc_header("Schema Provenance")
    lines.extend(
        [
            "Claude schemas are published JSON Schemas. Codex and Gemini schemas are local, docs-derived JSON Schemas maintained from the upstream references below.",
            "",
            "## Local Schemas",
            "",
            "| Schema | Title | Provenance |",
            "|---|---|---|",
        ]
    )
    lines.extend("| " + " | ".join(row) + " |" for row in schema_rows)
    lines.extend(["", "## Upstream References", ""])

    current_runtime = None
    for reference in UPSTREAM_REFERENCES:
        if reference.runtime != current_runtime:
            current_runtime = reference.runtime
            lines.extend(["", f"### {reference.runtime}", ""])
        lines.append(f"- {markdown_escape(reference.purpose)}: {reference.url}")
    lines.append("")
    return GeneratedDoc(DOCS / "schema-provenance.md", "\n".join(lines))


def no_mcp_variant_doc() -> GeneratedDoc:
    names = no_mcp_names()
    claude = marketplace_by_name(CLAUDE_MARKETPLACE)
    codex = marketplace_by_name(CODEX_MARKETPLACE)
    rows = []
    for name in names:
        rows.append(
            [
                f"`{markdown_escape(name)}`",
                markdown_escape(normalized_source(claude.get(name, {}).get("source"))),
                selector_cell(claude.get(name, {}).get("source")),
                markdown_escape(normalized_source(codex.get(name, {}).get("source"))),
                selector_cell(codex.get(name, {}).get("source")),
            ]
        )

    lines = doc_header("No-MCP Marketplace Variant")
    lines.extend(
        [
            "`marketplace-no-mcp` is a long-lived alternate branch for installs where MCP servers are already registered through the Labby gateway.",
            "",
            "The branch keeps plugin and skill entries available while removing bundled MCP server registrations from local plugin assets and Gemini extension manifests. It also points selected remote plugin sources at their own `marketplace-no-mcp` refs.",
            "",
            "Do not merge, delete, or retire this branch unless Jacob explicitly asks for that. Update `NO_MCP_REF_NAMES` in `plugins/scripts/apply-no-mcp-marketplace` when a new remote MCP-backed marketplace entry needs the alternate ref.",
            "",
            "The branch is synchronized by `.github/workflows/sync-marketplace-no-mcp.yml` after pushes to `main` and on a daily schedule. Drift is checked by `.github/workflows/check-no-mcp-drift.yml` and can be checked locally with `plugins/scripts/check-no-mcp-drift --compare-ref`.",
            "",
            "## Ref-Managed Entries",
            "",
            "| Plugin | Claude source | Claude selector | Codex source | Codex selector |",
            "|---|---|---|---|---|",
        ]
    )
    lines.extend("| " + " | ".join(row) + " |" for row in rows)
    lines.append("")
    return GeneratedDoc(DOCS / "no-mcp-variant.md", "\n".join(lines))


def generated_docs() -> list[GeneratedDoc]:
    return [
        plugin_matrix_doc(),
        configuration_matrix_doc(),
        marketplace_sources_doc(),
        schema_provenance_doc(),
        no_mcp_variant_doc(),
    ]


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--check", action="store_true", help="verify generated docs are up to date")
    args = parser.parse_args()

    stale: list[Path] = []
    DOCS.mkdir(exist_ok=True)
    for doc in generated_docs():
        contents = doc.contents
        if args.check:
            if not doc.path.exists() or doc.path.read_text() != contents:
                stale.append(doc.path.relative_to(ROOT))
        else:
            doc.path.write_text(contents)
            print(doc.path.relative_to(ROOT))

    if stale:
        print("Generated docs are out of date:", file=sys.stderr)
        for path in stale:
            print(f"- {path}", file=sys.stderr)
        return 1
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
