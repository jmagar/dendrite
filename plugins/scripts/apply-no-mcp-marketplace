#!/usr/bin/env python3
"""Apply Dendrite's no-MCP marketplace variant rules.

This script is intentionally deterministic so the long-lived
`marketplace-no-mcp` branch can be refreshed from `main` by automation.
It keeps plugin and skill entries intact while removing bundled MCP server
registrations for environments where MCP servers are already registered
through the Labby gateway.
"""

from __future__ import annotations

import json
import subprocess
import sys
from pathlib import Path
from typing import Any


ROOT = Path(__file__).resolve().parents[2]
PLUGINS = ROOT / "plugins"
CLAUDE_MARKETPLACE = ROOT / ".claude-plugin" / "marketplace.json"
CODEX_MARKETPLACE = ROOT / ".agents" / "plugins" / "marketplace.json"

NO_MCP_REF_NAMES = {
    "axon",
    "labby",
    "lumen",
    "rarcane",
    "rtemplate",
    "rustarr",
    "ytdl-mcp",
}

NO_MCP_REF = "marketplace-no-mcp"
NO_MCP_MARKETPLACE_NAME = "dendrite-no-mcp"


def read_json(path: Path) -> Any:
    return json.loads(path.read_text())


def write_json(path: Path, data: Any) -> None:
    path.write_text(json.dumps(data, indent=2, ensure_ascii=True) + "\n")


def remove_local_mcp_configs() -> list[Path]:
    removed = []
    for path in sorted(PLUGINS.glob("*/.mcp.json")):
        path.unlink()
        removed.append(path.relative_to(ROOT))
    return removed


def strip_gemini_mcp_servers() -> list[Path]:
    changed = []
    for path in sorted(PLUGINS.glob("*/gemini-extension.json")):
        data = read_json(path)
        if isinstance(data, dict) and "mcpServers" in data:
            data.pop("mcpServers")
            write_json(path, data)
            changed.append(path.relative_to(ROOT))
    return changed


def apply_no_mcp_refs(path: Path) -> list[str]:
    data = read_json(path)
    changed_name = False
    if data.get("name") != NO_MCP_MARKETPLACE_NAME:
        data["name"] = NO_MCP_MARKETPLACE_NAME
        changed_name = True

    plugins = data.get("plugins")
    if not isinstance(plugins, list):
        raise ValueError(f"{path.relative_to(ROOT)} must contain a plugins array")

    changed = []
    for plugin in plugins:
        if not isinstance(plugin, dict) or plugin.get("name") not in NO_MCP_REF_NAMES:
            continue
        source = plugin.get("source")
        if isinstance(source, dict) and source.get("ref") != NO_MCP_REF:
            source["ref"] = NO_MCP_REF
            changed.append(plugin["name"])

    if changed or changed_name:
        write_json(path, data)
    if changed_name:
        changed.insert(0, f"marketplace name -> {NO_MCP_MARKETPLACE_NAME}")
    return changed


def regenerate_generated_files() -> None:
    for script in (
        "generate-gemini-extensions",
        "generate-readme-inventory",
        "generate-docs",
    ):
        subprocess.run([sys.executable, str(ROOT / "plugins" / "scripts" / script)], check=True)


def main() -> int:
    removed_mcp = remove_local_mcp_configs()
    stripped_gemini = strip_gemini_mcp_servers()
    claude_refs = apply_no_mcp_refs(CLAUDE_MARKETPLACE)
    codex_refs = apply_no_mcp_refs(CODEX_MARKETPLACE)
    regenerate_generated_files()

    if removed_mcp:
        print("removed MCP configs: " + ", ".join(str(path) for path in removed_mcp))
    if stripped_gemini:
        print("stripped Gemini MCP servers: " + ", ".join(str(path) for path in stripped_gemini))
    if claude_refs:
        print("updated Claude marketplace refs: " + ", ".join(claude_refs))
    if codex_refs:
        print("updated Codex marketplace refs: " + ", ".join(codex_refs))

    if not any([removed_mcp, stripped_gemini, claude_refs, codex_refs]):
        print("no-MCP marketplace rules already applied")
    print("regenerated Gemini manifests, README inventory, and generated docs")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
