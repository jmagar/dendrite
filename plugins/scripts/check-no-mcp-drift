#!/usr/bin/env python3
"""Validate Dendrite's marketplace-no-mcp branch invariants and drift."""

from __future__ import annotations

import argparse
import json
import re
import shutil
import subprocess
import sys
import tempfile
from pathlib import Path
from typing import Any


ROOT = Path(__file__).resolve().parents[2]
NO_MCP_SCRIPT = ROOT / "plugins" / "scripts" / "apply-no-mcp-marketplace"
NO_MCP_REF = "marketplace-no-mcp"
NO_MCP_MARKETPLACE_NAME = "dendrite-no-mcp"


def run(command: list[str], *, cwd: Path = ROOT, check: bool = True) -> subprocess.CompletedProcess[str]:
    completed = subprocess.run(
        command,
        cwd=cwd,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        check=False,
    )
    if check and completed.returncode != 0:
        raise RuntimeError(
            f"`{' '.join(command)}` failed in {cwd} with exit {completed.returncode}:\n"
            f"{completed.stdout}"
        )
    return completed


def read_json(path: Path) -> Any:
    return json.loads(path.read_text())


def display_path(path: Path, root: Path) -> str:
    try:
        return str(path.relative_to(root))
    except ValueError:
        return str(path)


def no_mcp_ref_names() -> list[str]:
    text = NO_MCP_SCRIPT.read_text()
    match = re.search(r"NO_MCP_REF_NAMES\s*=\s*\{(?P<body>.*?)\}", text, re.S)
    if not match:
        raise ValueError(f"Could not parse NO_MCP_REF_NAMES from {display_path(NO_MCP_SCRIPT, ROOT)}")
    return sorted(re.findall(r'"([^"]+)"', match.group("body")))


def marketplace_ref_errors(path: Path, root: Path) -> list[str]:
    errors: list[str] = []
    data = read_json(path)
    if data.get("name") != NO_MCP_MARKETPLACE_NAME:
        errors.append(
            f"{display_path(path, root)} name is {data.get('name')!r}, "
            f"expected {NO_MCP_MARKETPLACE_NAME!r}"
        )
    plugins = data.get("plugins")
    if not isinstance(plugins, list):
        return [f"{display_path(path, root)} must contain a plugins array"]

    by_name = {plugin.get("name"): plugin for plugin in plugins if isinstance(plugin, dict)}
    for name in no_mcp_ref_names():
        plugin = by_name.get(name)
        if not isinstance(plugin, dict):
            errors.append(f"{display_path(path, root)} is missing no-MCP ref entry {name}")
            continue
        source = plugin.get("source")
        if not isinstance(source, dict):
            errors.append(f"{display_path(path, root)}:{name} source must be an object")
            continue
        if source.get("ref") != NO_MCP_REF:
            errors.append(
                f"{display_path(path, root)}:{name} source.ref is "
                f"{source.get('ref')!r}, expected {NO_MCP_REF!r}"
            )
    return errors


def current_invariant_errors(root: Path = ROOT) -> list[str]:
    errors: list[str] = []
    for relative in (".claude-plugin/marketplace.json", ".agents/plugins/marketplace.json"):
        errors.extend(marketplace_ref_errors(root / relative, root))

    mcp_configs = sorted((root / "plugins").glob("*/.mcp.json"))
    if mcp_configs:
        errors.append(
            "no-MCP branch must not contain local .mcp.json files:\n  "
            + "\n  ".join(str(path.relative_to(root)) for path in mcp_configs)
        )

    gemini_with_mcp: list[Path] = []
    for path in sorted((root / "plugins").glob("*/gemini-extension.json")):
        data = read_json(path)
        if isinstance(data, dict) and "mcpServers" in data:
            gemini_with_mcp.append(path)
    if gemini_with_mcp:
        errors.append(
            "no-MCP branch Gemini extensions must not declare mcpServers:\n  "
            + "\n  ".join(str(path.relative_to(root)) for path in gemini_with_mcp)
        )

    return errors


def check_current(*, root: Path = ROOT) -> int:
    errors = current_invariant_errors(root)
    if errors:
        print("no-MCP invariant check failed:", file=sys.stderr)
        for error in errors:
            print(f"- {error}", file=sys.stderr)
        return 1
    print("no-MCP invariant check passed")
    return 0


def fetch_ref_name(ref: str) -> str:
    return ref.removeprefix("origin/")


def compare_refs(main_ref: str, no_mcp_ref: str, *, skip_if_missing_refs: bool = False) -> int:
    tmp_parent = Path(tempfile.mkdtemp(prefix="dendrite-no-mcp-drift."))
    expected = tmp_parent / "expected"
    actual = tmp_parent / "actual"
    try:
        fetched = run(
            ["git", "fetch", "origin", fetch_ref_name(main_ref), fetch_ref_name(no_mcp_ref)],
            check=not skip_if_missing_refs,
        )
        if fetched.returncode != 0:
            print(
                "no-MCP drift compare skipped because refs could not be fetched:\n"
                f"{fetched.stdout}",
                file=sys.stderr,
            )
            return 0
        run(["git", "worktree", "add", "--detach", str(expected), main_ref])
        run(["git", "worktree", "add", "--detach", str(actual), no_mcp_ref])

        run(["python3", "plugins/scripts/apply-no-mcp-marketplace"], cwd=expected)

        if check_current(root=expected) != 0:
            return 1
        if check_current(root=actual) != 0:
            return 1

        run(["git", "add", "-A"], cwd=expected)
        expected_tree = run(["git", "write-tree"], cwd=expected).stdout.strip()
        actual_tree = run(["git", "rev-parse", "HEAD^{tree}"], cwd=actual).stdout.strip()
        if expected_tree != actual_tree:
            diff_output = run(
                ["git", "diff", "--stat", "--patch", actual_tree, expected_tree],
                cwd=expected,
                check=False,
            ).stdout
            print(
                f"{no_mcp_ref} does not match {main_ref} plus no-MCP transform:",
                file=sys.stderr,
            )
            print(diff_output, file=sys.stderr)
            return 1

        print("no-MCP drift compare passed")
        print(f"- main ref: {main_ref}")
        print(f"- no-MCP ref: {no_mcp_ref}")
        print(f"- tree: {actual_tree}")
        return 0
    finally:
        for path in (expected, actual):
            if path.exists():
                run(["git", "worktree", "remove", "--force", str(path)], check=False)
        shutil.rmtree(tmp_parent, ignore_errors=True)


def current_branch() -> str:
    return run(["git", "branch", "--show-current"]).stdout.strip()


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--check-current", action="store_true", help="check current checkout invariants")
    parser.add_argument("--compare-ref", action="store_true", help="compare origin/marketplace-no-mcp to origin/main plus transform")
    parser.add_argument(
        "--skip-if-missing-refs",
        action="store_true",
        help="skip compare mode when the configured remote refs cannot be fetched",
    )
    parser.add_argument("--main-ref", default="origin/main")
    parser.add_argument("--no-mcp-ref", default="origin/marketplace-no-mcp")
    args = parser.parse_args()

    if args.compare_ref:
        return compare_refs(args.main_ref, args.no_mcp_ref, skip_if_missing_refs=args.skip_if_missing_refs)

    if args.check_current:
        return check_current()

    if current_branch() == NO_MCP_REF:
        return check_current()

    print("not on marketplace-no-mcp; no-MCP current-branch check skipped")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
